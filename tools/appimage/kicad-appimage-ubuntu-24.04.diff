diff --git a/scripts/build_appimage.sh b/scripts/build_appimage.sh
index 9b3e4c0..01ca35c 100644
--- a/scripts/build_appimage.sh
+++ b/scripts/build_appimage.sh
@@ -6,6 +6,7 @@ set -euo pipefail
 
 APPDIR=${APPDIR:-/tmp/AppDir}
 OUTPUT_DIR=${OUTPUT_DIR:-/tmp}
+APPIMAGE_TOOL_DIR=${APPIMAGE_TOOL_DIR:-/usr/local/bin}
 ARCH=${ARCH:-x86_64}
 APP_VERSION=${APP_VERSION:-${KICAD_BUILD_RELEASE:-dev}}
 EXTRACT_DBGSYM=${EXTRACT_DBGSYM:-0}
@@ -42,16 +43,16 @@ fetch_sharun_tools(){
 
   wget -q "${sharun_url}" -O /tmp/sharun
   echo "${SHARUN_SHA256}  /tmp/sharun" | sha256sum -c -
-  install -m 0755 /tmp/sharun /usr/local/bin/sharun
+  install -m 0755 /tmp/sharun "${APPIMAGE_TOOL_DIR}/sharun"
 
   wget -q "${uruntime_url}" -O /tmp/uruntime
   echo "${URUNTIME_SHA256}  /tmp/uruntime" | sha256sum -c -
-  install -m 0755 /tmp/uruntime /usr/local/bin/uruntime
+  install -m 0755 /tmp/uruntime "${APPIMAGE_TOOL_DIR}/uruntime"
 
   wget -q "${dwarfs_url}" -O /tmp/dwarfs-universal
   echo "${DWARFS_SHA256}  /tmp/dwarfs-universal" | sha256sum -c -
-  install -m 0755 /tmp/dwarfs-universal /usr/local/bin/dwarfs-universal
