        (text "Before connecting a motor, set the A4988 current limit for the installed motor."))
      (instruction verify-polarity
        (scope component C1)
        (text "Verify C1 polarity and J1 motor-supply polarity before power-up.")))
    (firmware controller
      (data_base64 "")
      (format ihex)
      (sha256 "f004aae0a4b11cf8c1d3605762849af357b398f4db2c3800d8c7237dc0637c94")
      (bytes 9640)
      (version "1.0.0")
      (target U1)
      (device_code
        (toolchain arduino_cli)
        (toolchain_version "1.5.0")
        (target "arduino:avr:nano:cpu=atmega328")
        (entry "stepper_controller.ino")
        (file "stepper_controller.ino"
          (language arduino)
          (sha256 "25c3d97316762f6272902c8ab3f8557e195cf63e2d8c8a684397e5e8524e6338")
          (data_base64 ""))
