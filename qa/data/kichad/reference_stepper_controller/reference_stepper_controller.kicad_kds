          "f4e49fb6f5d6a043f7df792ef057143c542140508081aaa52d214a9ab33141c8")))
    (program controller
      (firmware controller)
      (target U1)
      (interface uart_bootloader)
      (connector U1)
      (device "ATmega328P")
      (voltage 5.0)
      (speed_khz 115)
      (erase required_regions)
      (reset run)
      (verify true)
      (signal tx 1)
      (signal rx 2)
      (signal gnd 4)
      (option baud "115200"))
    (power logic
      (connector U1)
      (positive_pin 27)
      (return_pin 4)
      (voltage 5.0)
      (current_limit 0.20)
      (settle_ms 250))
    (power motor
      (connector J1)
      (positive_pin 1)
      (return_pin 2)
      (voltage 12.0)
      (current_limit 0.50)
      (settle_ms 250))
    (test motor-input-open
      (stage unpowered)
      (method continuity)
      (instrument dmm)
      (target net VMOT)
      (expected open)
      (after_ms 0)
      (timeout_ms 5000)
      (required true)
      (procedure "Confirm no hard short from VMOT to GND; allow the bulk capacitor to charge."))
    (test logic-rail
      (stage power_on)
      (method voltage)
      (instrument dmm)
      (target net +5V)
      (range 4.75 5.25 V)
      (power logic)
      (after_ms 250)
      (timeout_ms 5000)
      (required true))
    (test motor-rail
      (stage power_on)
      (method voltage)
      (instrument dmm)
      (target net VMOT)
      (range 11.4 12.6 V)
      (power logic motor)
      (after_ms 250)
      (timeout_ms 5000)
      (required true))
    (test firmware-status
      (stage programmed)
      (method functional)
      (instrument fixture)
      (target component U1)
      (expected pass)
      (power logic)
      (program controller)
      (after_ms 500)
      (timeout_ms 5000)
      (required true)
      (procedure "Open 115200 baud serial, send STATUS, and require KICHAD_STEPPER_READY 1.0.0."))
    (test stepper-motion
      (stage functional)
      (method functional)
      (instrument fixture)
      (target component A1)
      (expected pass)
      (power logic motor)
      (program controller)
      (after_ms 250)
      (timeout_ms 15000)
      (required true)
      (procedure "Connect the fixture motor, send ENABLE then MOVE 200, require one forward revolution and OK MOVE, then require the driver disabled.")))
